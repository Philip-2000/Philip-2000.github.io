SSHFS_OPTS="-o reconnect,ServerAliveInterval=15,ServerAliveCountMax=3,IdentityFile=$HOME/.ssh/id_rsa,StrictHostKeyChecking=accept-new,follow_symlinks,attr_timeout=2,auto_cache,compression=no,idmap=user"

# Helper: get config by name
_sfs_get_cfg() {
    local target="$1" cfg name
    for cfg in "${SSHFS_CONFIG[@]}"; do
        IFS='|' read -r name _ _ _ <<< "$cfg"
        [[ "$name" == "$target" ]] && { echo "$cfg"; return 0; }
    done
    return 1
}

# List entries and status
sfs_list() {
    local cfg name remote local_dir extra
    for cfg in "${SSHFS_CONFIG[@]}"; do
        IFS='|' read -r name remote local_dir extra <<< "$cfg"
        [[ -z "$name" ]] && continue
        if mountpoint -q "$local_dir" 2>/dev/null; then
            printf "[mounted] %s -> %s @ %s\n" "$name" "$remote" "$local_dir"
        else
            printf "[off]     %s -> %s @ %s\n" "$name" "$remote" "$local_dir"
        fi
    done
}

# Mount one entry by name
sfs_mount() {
    local name="$1"
    [[ -z "$name" ]] && { echo "usage: sfs_mount <name>"; return 2; }
    command -v sshfs >/dev/null 2>&1 || { echo "sshfs not found"; return 1; }
    local cfg remote local_dir extra opts
    cfg="$(_sfs_get_cfg "$name")" || { echo "unknown entry: $name"; return 1; }
    IFS='|' read -r _ remote local_dir extra <<< "$cfg"
    mkdir -p "$local_dir"
    if mountpoint -q "$local_dir" 2>/dev/null; then
        echo "already mounted: $name"
        return 0
    fi
    opts="$SSHFS_OPTS"
    [[ -n "$extra" ]] && opts="${opts%,},$extra"
    sshfs $opts "$remote" "$local_dir"
}

# Unmount one entry by name
sfs_umount() {
    local name="$1"
    [[ -z "$name" ]] && { echo "usage: sfs_umount <name>"; return 2; }
    local cfg local_dir
    cfg="$(_sfs_get_cfg "$name")" || { echo "unknown entry: $name"; return 1; }
    IFS='|' read -r _ _ local_dir _ <<< "$cfg"
    if mountpoint -q "$local_dir" 2>/dev/null; then
        if command -v fusermount >/dev/null 2>&1; then
            fusermount -u "$local_dir" || sudo umount "$local_dir"
        else
            umount "$local_dir"
        fi
    else
        echo "not mounted: $name"
    fi
}

# Remount one entry
sfs_remount() { sfs_umount "$1" && sfs_mount "$1"; }

# Mount all defined entries
sfs_mount_all() {
    local cfg name
    for cfg in "${SSHFS_CONFIG[@]}"; do
        IFS='|' read -r name _ _ _ <<< "$cfg"
        [[ -n "$name" ]] && sfs_mount "$name"
    done
}

# Completions for names
_sfs_complete_names() {
    local names=() cfg name
    for cfg in "${SSHFS_CONFIG[@]}"; do
        IFS='|' read -r name _ _ _ <<< "$cfg"
        [[ -n "$name" ]] && names+=("$name")
    done
    COMPREPLY=( $(compgen -W "${names[*]}" -- "${COMP_WORDS[COMP_CWORD]}") )
}
complete -F _sfs_complete_names sfs_mount sfs_umount sfs_remount

