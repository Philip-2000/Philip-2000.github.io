update_bashrc(){
    L=1
    #reserve the first line of ~/.bashrc (maybe not necessary, so increase L if needed)
    head -n $L ~/.bashrc > ~/.bashrc_tmp
    #update the newer version of bashrc from $YL
    tail -n +$((L+1)) $YL/.bashrc >> ~/.bashrc_tmp
    mv ~/.bashrc_tmp ~/.bashrc
    source ~/.bashrc
    rm -f ~/.bashrc_tmp
}

set_server_info(){
    SERVER_INFO="$1"
    FIRST_LINE="SERVER_INFO=\"$SERVER_INFO\" #    "
    # Update the first line of ~/.bashrc
    sed -i "1s|.*|$FIRST_LINE|" ~/.bashrc
    source ~/.bashrc
}

