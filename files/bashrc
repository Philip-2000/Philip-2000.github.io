# 定义一个函数来缩短路径显示
shorten_path() {
    local path="$1"
    # 获取所有环境变量，筛选出值为路径的变量
    for var in ${PATH_VARS[@]} ; do
        local value="${!var}"
        # 检查该值是否为目录且当前路径在其下
        if [[ -d "$value" && ("$path" == "$value"/* || "$path" == "$value" )]]; then
            # 替换路径部分为环境变量名
            if [[ "$var" == "HOME" ]]; then
                echo "~${path#$value}"
            else
                echo $var"${path#$value}"
            fi
            return
        fi
    done
    # 如果没有匹配的环境变量，返回原路径
    echo "$path"
}

# 设置PS1，调用上面的函数
set_prompt() {
    local short_path=$(shorten_path "$PWD")
    local conda_env=""
    if [[ -n "$CONDA_DEFAULT_ENV" ]]; then
        conda_env="$CONDA_DEFAULT_ENV"  # 可选：保留 Conda 环境名
    fi
    # 设置PS1，使用缩短后的路径
    PS1="\[\033[01;32m\]${conda_env}\[\033[00m\]\[\033[01;34m\]>\u@${SERVER_NAME}<\[\033[00m\]\[\033[01;33m\]${short_path}\[\033[00m\]: "
}

