    if [ -f "./$1/bin/activate" ]; then
        source "./$1/bin/activate"
    elif [ -f "$CONDA_ROOT/envs/$1/bin/activate" ]; then
        source "$CONDA_ROOT/envs/$1/bin/activate"
    else
        echo "❌ Environment '$1' not found in current directory or Conda envs."
    fi
}

